# Copy to `.env.local` for `npm run dev` (Vite default mode is development).
# For separate dev vs production bundles (recommended for Capacitor), use the mode files below.

VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
RESEND_API_KEY=
FROM_EMAIL=
VITE_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=

# --- Mode-specific env (gitignored: `*.local`) ---
# `npm run build:dev` / `npm run build:mobile:dev` → Vite `--mode development`
#   Use `.env.development.local` (e.g. local Supabase with LAN IP for simulators).
#
# `npm run build:prod` / `npm run build:mobile:prod` → Vite `--mode production`
#   Use `.env.production.local` (e.g. Supabase Cloud for store builds).
#
